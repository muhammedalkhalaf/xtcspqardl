Package: xtcspqardl
Type: Package
Title: Cross-Sectionally Augmented Panel Quantile ARDL
Version: 1.0.2
Date: 2026-03-09
Authors@R: c(
    person("Muhammad", "Alkhalaf", 
           email = "muhammedalkhalaf@gmail.com",
           role = c("aut", "cre", "cph"),
           comment = c(ORCID = "0009-0002-2677-9246")),
    person("Merwan", "Roudane",
           role = "ctb",
